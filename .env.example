# ============================================================
# Client environment variables
# Create a .env file in /client with these values
# ============================================================

# IP of the machine running the Node.js backend
# Change to your server's LAN IP before deploying
REACT_APP_API_URL=http://192.168.0.10:3000

# Electron dev server port (CRA default is 3000, change if conflict)
PORT=3001
